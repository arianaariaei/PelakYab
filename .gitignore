# --- PelakYab ---
# NOTE: the pretrained model weights (models/*.pt) ARE committed on purpose,
# so the project runs without any training. Only ignore other weight formats.
models/*.onnx
models/*.engine

# large training datasets (not needed to run; download separately to train)
datasets/

# training output / plots
runs/

# runtime output
data/plates.json
data/images/

# generated at runtime (certs, tunnel binary, qr image)
certs/
tools/
connect_qr.png

# report build tooling (not part of the project)
report_build/

# python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# editors / os
.vscode/
.idea/
.DS_Store
Thumbs.db
